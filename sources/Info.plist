<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 基础应用信息 -->
    <key>CFBundleIdentifier</key>
    <string>com.quickfolderjump.app</string>
    
    <key>CFBundleName</key>
    <string>QuickFolderJump</string>
    
    <key>CFBundleDisplayName</key>
    <string>QuickFolderJump</string>
    
    <key>CFBundleShortVersionString</key>
    <string>2.1.0</string>
    
    <key>CFBundleVersion</key>
    <string>2.1.0</string>
    
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    
    <!-- 可执行文件名称 -->
    <key>CFBundleExecutable</key>
    <string>QuickFolderJump</string>
    
    <!-- 图标文件（可选，使用系统图标则不需要） -->
    <key>CFBundleIconFile</key>
    <string></string>
    
    <!-- 支持的界面方向 -->
    <key>UISupportedInterfaceOrientations</key>
    <array/>
    
    <!-- LSUIElement: 关键配置 -->
    <!-- 设置为 true 表示此应用不在 Dock 中显示图标，也没有主菜单栏 -->
    <!-- 应用以后台 accessory 模式运行，仅通过菜单栏图标和全局快捷键交互 -->
    <key>LSUIElement</key>
    <true/>
    
    <!-- LSBackgroundOnly 的替代，推荐用 LSUIElement -->
    <key>LSBackgroundOnly</key>
    <false/>
    
    <!-- 权限说明：辅助功能（Accessibility） -->
    <!-- 当应用首次请求辅助功能权限时，系统会向用户显示此说明 -->
    <key>NSAccessibilityUsageDescription</key>
    <string>QuickFolderJump 需要辅助功能权限来检测前台窗口是否为保存/打开对话框，以便自动导航到您选择的目录。</string>
    
    <!-- 权限说明：AppleEvents（控制其他应用，如 Finder） -->
    <key>NSAppleEventsUsageDescription</key>
    <string>QuickFolderJump 需要控制 Finder 的权限，以便在对话框中自动导航到您选择的目录。</string>
    
    <!-- 文件访问权限说明 -->
    <key>NSDocumentsFolderUsageDescription</key>
    <string>QuickFolderJump 需要访问您的文档目录以获取最近使用的文件夹列表。</string>
    
    <!-- 禁止应用进入 App Nap 模式，确保全局快捷键响应及时 -->
    <key>NSAppSleepDisabled</key>
    <true/>
    
    <!-- 高分辨率 Retina 显示支持 -->
    <key>NSHighResolutionCapable</key>
    <true/>
    
    <!-- 最小系统版本要求 -->
    <key>LSMinimumSystemVersion</key>
    <string>11.0</string>
    
    <!-- 主故事板（不使用，纯代码构建 UI） -->
    <key>NSMainStoryboardFile</key>
    <string></string>
    
    <!-- 启动时是否显示应用 -->
    <key>LSVisibleInClassic</key>
    <false/>
</dict>
</plist>
